-- Simple Held Lock Verification
BEGIN;
LOCK TABLE regress_lock_test IN ACCESS EXCLUSIVE MODE;
SELECT count(*) FROM dist_pg_locks WHERE lock_target = 'regress_lock_test' AND granted;
 count 
-------
